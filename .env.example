# Entorno: local | dev | test | prod
NODE_ENV=local

# Marca / plantilla
BOT_DISPLAY_NAME=Zycryx Bot
BOT_PACKAGE_NAME=Zycryx Stickers
BOT_AUTHOR=Zycryx
BOT_BANNER_NAME=ZYCRYX BOT
BOT_BANNER_AUTHOR=by: Zycryx
BOT_REPOSITORY_URL=
BOT_WEBSITE_URL=
BOT_YOUTUBE_URL=
BOT_TIKTOK_URL=
BOT_FACEBOOK_URL=
BOT_INSTAGRAM_URL=
BOT_GROUP_LINKS=
BOT_CHANNEL_LINKS=
BOT_MOD_GROUP_ID=
# Owners normales: numeros internacionales sin +, separados por coma.
# Ejemplo: BOT_OWNER_NUMBERS=573001112233,51999888777
BOT_OWNER_NUMBERS=
# Owners reales/root: JIDs completos de WhatsApp, separados por coma.
# Estos pueden usar comandos marcados como rowner.
# Ejemplo: BOT_FIXED_OWNER_JIDS=573001112233@s.whatsapp.net,51999888777@s.whatsapp.net
BOT_FIXED_OWNER_JIDS=
DEFAULT_MENU_IMAGE=./media/Menu2.jpg
DATA_SOURCE=local
LOG_LEVEL=command
PERF_LOG_THRESHOLD_MS=750
HTTP_TIMEOUT_MS=15000

# Backend futuro: DATA_SOURCE=backend
BACKEND_PROTOCOL=rest
BACKEND_BASE_URL=
BACKEND_API_TOKEN=
BACKEND_TIMEOUT_MS=10000

# APIs externas
API_BASE_URL=https://api.delirius.store
API_KEY=
FGMODS_API_URL=https://api.fgmods.xyz/api
FGMODS_API_KEY=
NEOXR_API_URL=https://api.neoxr.eu/api
NEOXR_API_KEY=
ACR_HOST=identify-eu-west-1.acrcloud.com
ACR_ACCESS_KEY=
ACR_ACCESS_SECRET=
ALYACHAN_API_KEY=
BETABOTZ_API_KEY=
LOLHUMAN_API_KEY=
TENOR_API_KEY=
TELEGRAM_BOT_TOKEN=
SKYULTRA_API_KEY=
UNSPLASH_ACCESS_KEY=
ZENKEY_API_KEY=
TRANSLATE_API_KEY=
PERPLEXITY_API_KEYS=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_ENABLED=true
VIRUSTOTAL_MAX_FILE_MB=32
VIRUSTOTAL_POLL_ATTEMPTS=6
VIRUSTOTAL_POLL_INTERVAL_MS=10000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zycryx_bot
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=public
# Alternativa: usar DATABASE_URL en lugar de los parámetros individuales
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db
