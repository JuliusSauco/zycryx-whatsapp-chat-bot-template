{
  "name": "zycryx-whatsapp-chat-bot-template",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "clean": "if exist dist rmdir /s /q dist 2>nul & if exist tsconfig.tsbuildinfo del /f /q tsconfig.tsbuildinfo 2>nul",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:helpers && npm run test:router && npm run test:guards && npm run test:context && npm run test:services && npm run test:security && npm run test:providers && npm run test:p0",
    "test:helpers": "tsx tests/helpers.test.ts",
    "test:router": "tsx tests/router.test.ts",
    "test:guards": "tsx tests/guards.test.ts",
    "test:context": "tsx tests/context-builder.test.ts",
    "test:services": "tsx tests/services.test.ts",
    "test:security": "tsx tests/sensitive-command.test.ts",
    "test:providers": "tsx tests/download-providers.test.ts",
    "test:p0": "tsx tests/p0-architecture.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:ensure-schema": "tsx src/db/ensure-schema.ts",
    "db:migrate": "npm run db:ensure-schema && drizzle-kit migrate",
    "db:setup": "npm run db:migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "cross-env NODE_ENV=local tsx watch src/core/index.ts",
    "dev:dev": "cross-env NODE_ENV=dev tsx watch src/core/index.ts",
    "dev:test": "cross-env NODE_ENV=test tsx watch src/core/index.ts",
    "postinstall": "tsc",
    "serve": "cross-env NODE_ENV=prod node --max-old-space-size=512 dist/core/index.js",
    "serve:local": "cross-env NODE_ENV=local node --max-old-space-size=512 dist/core/index.js",
    "serve:dev": "cross-env NODE_ENV=dev node --max-old-space-size=512 dist/core/index.js",
    "serve:test": "cross-env NODE_ENV=test node --max-old-space-size=512 dist/core/index.js",
    "serve:migrate": "npm run db:migrate && npm run serve",
    "serve:local:migrate": "npm run db:migrate && npm run serve:local",
    "serve:dev:migrate": "npm run db:migrate && npm run serve:dev",
    "serve:test:migrate": "npm run db:migrate && npm run serve:test",
    "start": "npm run build && npm run serve",
    "start:local": "npm run build && npm run serve:local",
    "start:dev": "npm run build && npm run serve:dev",
    "start:test": "npm run build && npm run serve:test",
    "start:migrate": "npm run build && npm run db:migrate && npm run serve",
    "start:local:migrate": "npm run build && npm run db:migrate && npm run serve:local",
    "start:dev:migrate": "npm run build && npm run db:migrate && npm run serve:dev",
    "start:test:migrate": "npm run build && npm run db:migrate && npm run serve:test",
    "bun:start": "cross-env NODE_ENV=prod bun run src/core/index.ts",
    "bun:start:dev": "cross-env NODE_ENV=dev bun run src/core/index.ts",
    "bun:start:local": "cross-env NODE_ENV=local bun run src/core/index.ts"
  },
  "dependencies": {
    "@bochilteam/scraper": "^5.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "api-dylux": "^1.8.3",
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^5.0.5",
    "cfonts": "^3.3.0",
    "chalk": "^5.3.0",
    "cheerio": "1.0.0-rc.12",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "file-type": "^18.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "formdata-node": "^5.0.0",
    "fuzzysort": "^1.0.0",
    "hispamemes": "^1.0.7",
    "human-readable": "^0.2.1",
    "jimp": "^1.6.0",
    "link-preview-js": "^3.0.0",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.2.10",
    "node-gtts": "^2.0.2",
    "node-webpmux": "^3.1.3",
    "openai": "^3.3.0",
    "pino": "^8.0.0",
    "qrcode": "^1.5.0",
    "qrcode-terminal": "^0.12.0",
    "readline-sync": "^1.4.10",
    "syntax-error": "^1.4.0",
    "url-file-size": "^1.0.5-1",
    "yargs": "^17.7.2",
    "yt-search": "^2.12.1",
    "ytdl-core": "^4.11.5"
  },
  "optionalDependencies": {
    "moment-timezone": "^0.5.37",
    "pg": "^8.11.3",
    "wa-sticker-formatter": "^4.4.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/yargs": "^17.0.35",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
